# Optional shared coordination. Leave empty for single-controller in-memory mode.
DATABASE_URL=
REDIS_URL=
REDIS_PREFIX=agapornis
# Enable this on every replica when the API runs behind a load balancer.
# Shared SQL and Redis are required; HTTP sessions remain stateless.
API_CLUSTERED=false
API_REPLICAS=1
TRUST_PROXY=false

# Host-native release manifests. Defaults point to the three public Agapornis
# repositories; override these only for a mirror or a private release channel.
AGAPORNIS_API_RELEASE_MANIFEST_URL=https://github.com/agapornis-dev/agapornis-api/releases/latest/download/release-manifest.json
AGAPORNIS_FRONTEND_RELEASE_MANIFEST_URL=https://github.com/agapornis-dev/agapornis-frontend/releases/latest/download/release-manifest.json
AGAPORNIS_AGENT_RELEASE_MANIFEST_URL=https://github.com/agapornis-dev/agapornis-agent-rust/releases/latest/download/release-manifest.json

# Native update staging and supervisor. The recommended systemd setup grants
# the agapornis user permission to start only agapornis-panel-update.service.
AGAPORNIS_PANEL_UPDATE_DIR=/var/lib/agapornis/api/panel-updates
AGAPORNIS_PANEL_UPDATE_COMMAND=/usr/bin/sudo
AGAPORNIS_PANEL_UPDATE_ARGS=["/bin/systemctl","start","--no-block","agapornis-panel-update.service"]
AGAPORNIS_PANEL_UPDATE_COMMAND_CWD=/opt/agapornis
AGAPORNIS_PANEL_UPDATE_MAX_BYTES=536870912
AGAPORNIS_PANEL_UPDATE_TIMEOUT_MS=3600000

# Browser origins allowed to call the API directly. This is an exact,
# comma-separated allowlist; paths are ignored and wildcard origins are not
# accepted. PANEL_PUBLIC_URL / FRONTEND_URL / APP_URL are also trusted.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Live server metrics. One shared poll is used per viewed server.
SERVER_STATS_STREAM_INTERVAL_MS=1000
SERVER_STATS_STREAM_START_DELAY_MS=75

APP_JWT_SECRET=agapornis

# Owner defaults; the Owner can change these in Panel Settings.
BACKUP_S3_ALLOWED=false
BACKUP_S3_DEFAULT=false
BACKUP_S3_RETENTION_COUNT=7
BACKUP_S3_ENCRYPTION_REQUIRED=true
BACKUP_VERIFY_INTERVAL_HOURS=24

# Rotate managed node certificates this many days before expiry.
AGENT_CERT_AUTO_ROTATE_DAYS_BEFORE_EXPIRY=30

# Long-running egg installers use a one-hour deadline by default.
AGENT_GRPC_CREATE_SERVER_TIMEOUT_MS=3600000
